// File name: projects/1/Or.hdl
/**
 * Or gate:
 * if (a or b) out = 1, else out = 0
 */
CHIP Or {
    IN a, b;
    OUT out;

    PARTS:
    Not(in=a, out=Nota);
    Not(in=b, out=Notb);

    // Method 1
    // Nand(a=Nota, b=Notb, out=out);

    // Method 2
    And(a=Nota, b=Notb, out=x);
    Not(in=x, out=out);

}
